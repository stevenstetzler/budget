# --- IGNORE EVERYTHING GENERATED BY THE BUILD ---
build/
app/build/
*.pyc
*.class

# --- IGNORE LOCAL IDE SETTINGS (Personal to your computer) ---
.idea/
*.iml
.gradle/
local.properties
.DS_Store

# --- IGNORE SENSITIVE FILES ---
*.jks
*.keystore

# --- PYTHON ---
*.db
__pycache__/
*.egg-info/
.venv/

# --- PERSONAL FINANCE / DATA EXPORTS ---
*.csv
*.xlsx
*.xls
*.db-wal
*.db-shm
exports/

# --- THE "INCLUDE" SECTION (Whitelisting) ---
# We ignore the entire gradle wrapper folder to be safe...
gradle/wrapper/*

# ...BUT we "include" the specific files needed to build the project
!gradle/wrapper/gradle-wrapper.jar
!gradle/wrapper/gradle-wrapper.properties